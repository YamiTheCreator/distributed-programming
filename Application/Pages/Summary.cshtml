@page
@model Application.Pages.SummaryModel
@{
    ViewData["Title"] = "Результаты анализа";
}

<div class="container">
    <h2>Результаты анализа текста</h2>
    
    @if (Model.AnalysisResult != null)
    {
        <div class="analysis-results">
            <div class="result-item">
                <label>Оценка содержания:</label>
                <span id="rank-value">
                    @if (Model.AnalysisResult.Rank.HasValue)
                    {
                        @Model.AnalysisResult.Rank
                    }
                    else
                    {
                        <span class="loading">Вычисляется...</span>
                        <div class="spinner"></div>
                    }
                </span>
            </div>
            
            <div class="result-item">
                <label>Плагиат:</label>
                <span id="similarity-value">@Model.AnalysisResult.Similarity</span>
            </div>
        </div>
        
        <div class="actions">
            <a href="/" class="btn btn-primary">Анализировать новый текст</a>
        </div>
    }
    else
    {
        <div class="error">
            <p>Ошибка загрузки данных</p>
            <a href="/" class="btn btn-secondary">Вернуться на главную</a>
        </div>
    }
</div>

<style>
    .analysis-results {
        margin: 20px 0;
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 8px;
        background-color: #f9f9f9;
    }
    
    .result-item {
        margin: 15px 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .result-item label {
        font-weight: bold;
        color: #333;
    }
    
    .loading {
        color: #007bff;
        font-style: italic;
    }
    
    .spinner {
        display: inline-block;
        width: 16px;
        height: 16px;
        border: 2px solid #f3f3f3;
        border-top: 2px solid #007bff;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-left: 10px;
    }
    
    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    
    .actions {
        margin-top: 30px;
        text-align: center;
    }
    
    .btn {
        padding: 10px 20px;
        text-decoration: none;
        border-radius: 4px;
        display: inline-block;
        margin: 0 10px;
    }
    
    .btn-primary {
        background-color: #007bff;
        color: white;
    }
    
    .btn-secondary {
        background-color: #6c757d;
        color: white;
    }
    
    .error {
        text-align: center;
        color: #dc3545;
        margin: 20px 0;
    }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const urlParams = new URLSearchParams(window.location.search);
            const analysisId = urlParams.get('id');
            
            if (!analysisId) {
                console.error('Analysis ID not found');
                return;
            }
            
            const isCompleted = @(Model.AnalysisResult?.Rank.HasValue.ToString().ToLower() ?? "false");
            
            if (isCompleted === "true") {
                console.log('Analysis already completed');
                return;
            }
            
            console.log('Connecting to SignalR for analysis:', analysisId);
            
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("http://localhost:8080/notificationHub")
                .withAutomaticReconnect()
                .build();
            
            connection.on("RankCalculationCompleted", function (result) {
                console.log('Received result:', result);
                
                if (result.id === analysisId) {
                    console.log('Updating UI with rank:', result.rank);
                    const rankElement = document.getElementById('rank-value');
                    if (rankElement && result.rank !== undefined) {
                        rankElement.innerHTML = result.rank;
                    }
                    connection.stop();
                }
            });
            
            connection.start()
                .then(() => {
                    console.log('SignalR connected');
                    return connection.invoke("JoinAnalysisGroup", analysisId);
                })
                .then(() => {
                    console.log('Joined group:', analysisId);
                })
                .catch(err => {
                    console.error('SignalR error:', err);
                    const rankElement = document.getElementById('rank-value');
                    if (rankElement) {
                        rankElement.innerHTML = `
                            <span style="color: #dc3545;">
                                Ошибка подключения. 
                                <a href="javascript:location.reload()">Обновить</a>
                            </span>
                        `;
                    }
                });
        });
    </script>
}
